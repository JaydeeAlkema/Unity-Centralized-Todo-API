@baseUrl = http://localhost:5186
@projectKey = unity-centralized-todo
@otherProjectKey = another-unity-project

# Standardized error shape (for Unity/client parsing):
# {
#   "code": "...",
#   "message": "...",
#   "field": "...",
#   "status": 400,
#   "traceId": "..."
# }

# -----------------------------------------------------------------------
# BASELINE
# -----------------------------------------------------------------------

GET {{baseUrl}}/

###

# List all known projects (expected: 200, empty array before any todos exist)
GET {{baseUrl}}/projects

###

# -----------------------------------------------------------------------
# CREATE — run these first; all subsequent requests assume todo id=1 exists
# -----------------------------------------------------------------------

# Create todo in primary project (expected: 201)
POST {{baseUrl}}/projects/{{projectKey}}/todos
Content-Type: application/json

{
	"name": "Buy groceries",
	"severity": "high",
	"dueDate": "2026-04-30T17:00:00Z",
	"isComplete": false
}

###

# Create todo in a second project to verify isolation (expected: 201)
POST {{baseUrl}}/projects/{{otherProjectKey}}/todos
Content-Type: application/json

{
	"name": "Fix shader warnings",
	"severity": "medium",
	"dueDate": "2026-05-02T11:00:00Z",
	"isComplete": false
}

###

# List projects after creating todos (expected: 200, both projects listed)
GET {{baseUrl}}/projects

###

# -----------------------------------------------------------------------
# READ — project isolation check
# -----------------------------------------------------------------------

# Primary project todos — should NOT include the shader warning todo (expected: 200, 1 item)
GET {{baseUrl}}/projects/{{projectKey}}/todos

###

# Other project todos — should NOT include the groceries todo (expected: 200, 1 item)
GET {{baseUrl}}/projects/{{otherProjectKey}}/todos

###

# Read single todo by id (expected: 200)
GET {{baseUrl}}/projects/{{projectKey}}/todos/1

###

# -----------------------------------------------------------------------
# FILTER
# -----------------------------------------------------------------------

# Filter by severity and completion state (expected: 200, returns groceries)
GET {{baseUrl}}/projects/{{projectKey}}/todos?severity=high&isComplete=false&sortBy=dueDate

###

# Filter by due range and search text (expected: 200, returns groceries)
GET {{baseUrl}}/projects/{{projectKey}}/todos?dueFrom=2026-04-01T00:00:00Z&dueTo=2026-05-01T00:00:00Z&search=groceries&sortBy=name

###

# -----------------------------------------------------------------------
# UPDATE
# -----------------------------------------------------------------------

# Update todo (expected: 200)
PUT {{baseUrl}}/projects/{{projectKey}}/todos/1
Content-Type: application/json

{
	"name": "Buy groceries and cook dinner",
	"severity": "critical",
	"dueDate": "2026-04-30T18:00:00Z",
	"isComplete": false
}

###

# Conflict sample — 409 only occurs under concurrent PUT requests; in serial testing this returns 200.
# Run this BEFORE the DELETE below if you want to observe the request shape for a conflict scenario.
PUT {{baseUrl}}/projects/{{projectKey}}/todos/1
Content-Type: application/json

{
	"name": "Potential concurrent update",
	"severity": "high",
	"dueDate": "2026-05-01T10:30:00Z",
	"isComplete": true
}

###

# -----------------------------------------------------------------------
# DELETE
# -----------------------------------------------------------------------

# Delete todo (expected: 204)
DELETE {{baseUrl}}/projects/{{projectKey}}/todos/1

###

# Not found after delete (expected: 404, code: resource.todo_not_found)
GET {{baseUrl}}/projects/{{projectKey}}/todos/1

###

# -----------------------------------------------------------------------
# NOT FOUND CASES
# -----------------------------------------------------------------------

# Delete missing todo (expected: 404, code: resource.todo_not_found)
DELETE {{baseUrl}}/projects/{{projectKey}}/todos/999

###

# Update missing todo (expected: 404, code: resource.todo_not_found)
PUT {{baseUrl}}/projects/{{projectKey}}/todos/999
Content-Type: application/json

{
	"name": "Update missing todo",
	"severity": "low",
	"dueDate": "2026-05-01T10:00:00Z",
	"isComplete": true
}

###

# -----------------------------------------------------------------------
# VALIDATION ERRORS
# -----------------------------------------------------------------------

# Empty name (expected: 400, code: validation.name_required)
POST {{baseUrl}}/projects/{{projectKey}}/todos
Content-Type: application/json

{
	"name": "   ",
	"severity": "low",
	"dueDate": "2026-04-30T17:00:00Z",
	"isComplete": false
}

###

# Due date in the past (expected: 400, code: validation.due_date_past)
POST {{baseUrl}}/projects/{{projectKey}}/todos
Content-Type: application/json

{
	"name": "Past date test",
	"severity": "medium",
	"dueDate": "2020-01-01T00:00:00Z",
	"isComplete": false
}

###

# Invalid severity value (expected: 400, code: validation.severity_invalid)
POST {{baseUrl}}/projects/{{projectKey}}/todos
Content-Type: application/json

{
	"name": "Severity test",
	"severity": "urgent",
	"dueDate": "2026-04-30T17:00:00Z",
	"isComplete": false
}

###

# Invalid project key — starts with underscore, fails allowed pattern (expected: 400, code: validation.project_key_invalid)
GET {{baseUrl}}/projects/_invalid-key/todos

###

# Id must be positive (expected: 400, code: validation.id_non_positive)
GET {{baseUrl}}/projects/{{projectKey}}/todos/0

###

# Due range reversed — dueFrom is after dueTo (expected: 400, code: validation.due_range_invalid)
GET {{baseUrl}}/projects/{{projectKey}}/todos?dueFrom=2026-05-02T00:00:00Z&dueTo=2026-05-01T00:00:00Z